{
  "name": "opstalk",
  "version": "2.7.5",
  "description": "Interactive terminal chat CLI for AWS DevOps Agent",
  "type": "module",
  "bin": {
    "opstalk": "dist/cli/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "bash scripts/setup-git-secrets.sh || true"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.918.0",
    "@smithy/eventstream-serde-node": "^4.2.5",
    "@smithy/protocol-http": "^5.3.5",
    "@smithy/signature-v4": "^5.3.5",
    "commander": "^14.0.1",
    "ink": "^6.3.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inceptionstack/opstalk.git"
  },
  "homepage": "https://github.com/inceptionstack/opstalk",
  "keywords": [
    "aws",
    "devops",
    "agent",
    "cli",
    "tui",
    "chat",
    "terminal",
    "ink"
  ],
  "author": "InceptionStack",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
